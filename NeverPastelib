Services.UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if ListeningKeybindEntry then
        if input.KeyCode == Enum.KeyCode.Escape then
            ListeningKeybindEntry.bind = nil
        elseif input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode ~= Enum.KeyCode.Unknown then
            ListeningKeybindEntry.bind = input.KeyCode
        elseif input.UserInputType == Enum.UserInputType.MouseButton2
            or input.UserInputType == Enum.UserInputType.MouseButton3 then
            ListeningKeybindEntry.bind = input.UserInputType
        else
            return
        end

        safeCallback(ListeningKeybindEntry.changed, ListeningKeybindEntry.bind)
        ListeningKeybindEntry = nil
        refreshRows()
        return
    end

    if BindPopupCurrent and BindPopupListening then
        if input.KeyCode == Enum.KeyCode.Escape then
            BindPopupCurrent.bind = nil
            closeBindPopup()
        elseif input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode ~= Enum.KeyCode.Unknown then
            BindPopupCurrent.bind = input.KeyCode
            BindPopupListening = false
        elseif input.UserInputType == Enum.UserInputType.MouseButton2
            or input.UserInputType == Enum.UserInputType.MouseButton3 then
            BindPopupCurrent.bind = input.UserInputType
            BindPopupListening = false
        end

        refreshRows()
        refreshKeybindList()
        return
    end

    if BindPopupShell.outline.Visible and (
        input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.MouseButton2
        or input.UserInputType == Enum.UserInputType.Touch
    ) then
        local inputPosition = Vector2.new(input.Position.X, input.Position.Y)

        if not isInsideGui(BindPopupShell.outline, inputPosition) then
            closeBindPopup()
        end
    end

    if PickerShell.outline.Visible and (
        input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.MouseButton2
        or input.UserInputType == Enum.UserInputType.Touch
    ) then
        local inputPosition = Vector2.new(input.Position.X, input.Position.Y)

        if not isInsideGui(PickerShell.outline, inputPosition) then
            closePicker()
        end
    end

    if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.MouseButton2
        or input.UserInputType == Enum.UserInputType.Touch then
        local inputPosition = Vector2.new(input.Position.X, input.Position.Y)

        if SearchOpen
            and not isInsideGui(SearchShell.outline, inputPosition)
            and not isInsideGui(SearchButton, inputPosition) then
            closeSearch()
        end

        if InfoOpen
            and not isInsideGui(InfoShell.outline, inputPosition)
            and not isInsideGui(InfoButton, inputPosition) then
            closeInfo()
        end

        if SettingsOpen
            and not isInsideGui(SettingsShell.outline, inputPosition)
            and not isInsideGui(SettingsButton, inputPosition) then
            closeSettings()
        end
    end

    if gameProcessed then
        return
    end

    if input.KeyCode == MenuToggleBind then
        MenuVisible = not MenuVisible
        stopMenuTween()

        if MenuVisible then
            Window.Visible = true
            local show = tween(Window, 0.18, {
                BackgroundTransparency = 0,
                Position = UDim2.new(0.5, -96, 0.5, -16),
            })
            ActiveMenuTween = show
            local done
            done = show.Completed:Connect(function()
                if done then
                    done:Disconnect()
                end
                if ActiveMenuTween == show then
                    ActiveMenuTween = nil
                end
            end)
        else
            closePicker()
            closeBindPopup()
            closeMiniPanels()
            table.clear(ActiveHoldEntries)
            local hide = tween(Window, 0.18, {
                BackgroundTransparency = 1,
                Position = UDim2.new(0.5, -96, 0.5, -8),
            })
            ActiveMenuTween = hide
            local done
            done = hide.Completed:Connect(function()
                if done then
                    done:Disconnect()
                end
                if ActiveMenuTween == hide then
                    ActiveMenuTween = nil
                end
                if not MenuVisible then
                    Window.Visible = false
                end
            end)
        end

        return
    end

    if input.KeyCode == Enum.KeyCode.Escape and PickerShell.outline.Visible then
        closePicker()
        return
    end

    if input.KeyCode == Enum.KeyCode.Escape and BindPopupShell.outline.Visible then
        closeBindPopup()
        return
    end

    if input.KeyCode == Enum.KeyCode.Escape and (SearchOpen or InfoOpen or SettingsOpen) then
        closeMiniPanels()
        return
    end

    for _, entry in ipairs(Entries) do
        if entry.kind == "toggle" and entry.mode ~= "always" and inputMatchesBind(entry.bind, input) then
            if entry.mode == "hold" then
                entry.state = true
                ActiveHoldEntries[entry] = true
            else
                entry.state = not entry.state
            end
            safeCallback(entry.callback, entry.state)
        elseif entry.kind == "keybind" and inputMatchesBind(entry.bind, input) then
            safeCallback(entry.callback, bindToText(entry.bind), entry.bind)
        end
    end

    refreshRows()
    updateWatermark()
end)

Services.RunService.RenderStepped:Connect(function(deltaTime)
    FpsFrames = FpsFrames + 1
    FpsElapsed = FpsElapsed + deltaTime

    if FpsElapsed >= 2 then
        CurrentFps = math.floor(FpsFrames / FpsElapsed + 0.5)
        CurrentPing = getPing()
        FpsFrames = 0
        FpsElapsed = 0
    end

    if PickerOpen then
