    local watermarkColor = Theme.accent
    local now = time()

    WatermarkShell.outline.Visible = visible
    WatermarkShell.accent.BackgroundColor3 = watermarkColor

    if visible and (now - LastWatermarkTextUpdate >= 1 or WatermarkText.Text == "") then
        WatermarkText.Text = string.format(
            "  %s | %s : %s : %s : %d FPS : %d MS  ",
            Runtime.title,
            LocalPlayer.Name,
            placeName,
            os.date("%H:%M:%S"),
            CurrentFps,
            CurrentPing
        )
        WatermarkWidth = math.max(WatermarkWidth, WatermarkText.TextBounds.X + 16)
        WatermarkShell.outline.Size = UDim2.fromOffset(WatermarkWidth, 24)
        LastWatermarkTextUpdate = now
    end
end

